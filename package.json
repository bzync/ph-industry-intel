{
  "name": "@bzync/ph-industry-intel",
  "version": "0.1.0",
  "description": "Headless Philippine industry lookup library with official PSIC hierarchy and search utilities",
  "keywords": [
    "philippines",
    "industry",
    "psic",
    "philippine-standard-industrial-classification",
    "business",
    "classification",
    "government-aligned",
    "saas",
    "taxonomy",
    "ph"
  ],
  "author": {
    "name": "Rayan Vega Reynaldo",
    "email": "rayanvegareynaldo@gmail.com",
    "url": "https://github.com/rvrdev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bzync/ph-industry-intel.git"
  },
  "homepage": "https://github.com/bzync/ph-industry-intel",
  "bugs": {
    "url": "https://github.com/bzync/ph-industry-intel/issues"
  },
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/rvrdev"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate:psic-data": "tsx scripts/prepare-psic-data.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
